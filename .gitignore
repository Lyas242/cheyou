# ========================================
# 车优 (EV-Compass) - Git 忽略配置
# ========================================

# ========================================
# 通用
# ========================================
.DS_Store
Thumbs.db
*.log
*.swp
*.swo
*~

# ========================================
# IDE
# ========================================
.idea/
.vscode/
*.iml
*.ipr
*.iws

# ========================================
# Python
# ========================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# 虚拟环境
.venv/
venv/
ENV/
env/

# ========================================
# Node.js / Vue
# ========================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# 构建输出
dist/
dist-ssr/
*.local

# Vite
.vite/

# ========================================
# Java / Spring Boot
# ========================================
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# ========================================
# 环境变量 (敏感信息)
# ========================================
.env
.env.local
.env.*.local

# ========================================
# 数据库
# ========================================
*.db
*.sqlite
*.sqlite3

# ========================================
# 其他
# ========================================
.history/
problem/
screenshots/
*.bak
*.tmp

# 日志
logs/
*.log
